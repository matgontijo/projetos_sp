# --- Banco de dados ---
# Padrao (sem definir nada): SQLite local em backend/custeio.db — bom para testar.
# Producao: PostgreSQL (suba com `docker compose up -d db` na raiz do projeto):
# DATABASE_URL=postgresql+psycopg://custeio:custeio@localhost:5432/custeio

# --- Criptografia das credenciais Omie (obrigatorio em producao) ---
# Gere uma chave com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Se nao definir, o app gera e guarda uma chave em backend/.secret_key (apenas dev).
# APP_ENCRYPTION_KEY=

# --- CORS (origens do frontend) ---
# CORS_ORIGINS=http://localhost:5173

# --- Omie ---
# OMIE_BASE_URL=https://app.omie.com.br/api/v1
# OMIE_MIN_INTERVAL=0.35
